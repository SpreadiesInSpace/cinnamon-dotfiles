#!/usr/bin/env xdg-open

[Desktop Entry]
Name=Mount CIFS Share
Exec=gnome-terminal -- bash -c 'mount -t cifs //192.168.1.127/Share /root/Share -o username=f16poom,password=,uid=1000,gid=1000,workgroup=workgroup;clear;neofetch;exec bash;'
Comment=
Terminal=false
Icon=software
Type=Application
Hidden=false
NoDisplay=false
